// Velkommen!
// Dette er en side der du kan øve på å kjøre analyser i microdata.no.

//- Denne siden inneholder ikke ekte tall, det er et hobbyprosjekt og er ikke laget av microdata.no selv. Den kommer også uten garantier for at analysene er korrekt implementert.

// La oss starte med et eksempel
//- Du kan endre det fritt eller hente et nytt under eksempler i menyen.

// Først må vi koble oss opp mot basen med data
require no.ssb.fdb:51 as db  // Her lager vi koblingen og gir den et navn (db).

create-dataset df  // Vi starter så med å opprette et nytt datasett kalt df

// Vi kan så importere ulike variabler
import db/BEFOLKNING_KJOENN as kjonn
import db/INNTEKT_LONN 2022-12-31 as inntekt  // Akkumulerte variabler krever en importdato (YYYY-MM-DD)
// Nå har vi hentet data fra databasen (db) og gitt variablene nye navn.
// Husk at du kan trykke TAB for å få hjelp med kommandoer og variabler

// Da er vi klare til å analysere.
summarize inntekt // Kommandoen vises gjennomsnitt, standardavvik og mer
tabulate kjonn    // Tabellen viser fordelingen mellom kjønnene i datasettet
barchart kjonn    // Til slutt lager vi et stolpediagram over kjønnsfordelingen